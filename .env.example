# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/automindz

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-change-this
JWT_EXPIRES_IN=7d

# Encryption (32 byte hex key for AES-256)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# App
APP_URL=http://localhost:5173
SERVER_URL=http://localhost:5000

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/accounts/google/callback

# NOTE: Google OAuth Login uses a DIFFERENT redirect URI:
#   http://localhost:5000/api/auth/google/callback
# Add BOTH URLs to your Google Cloud Console → Authorized redirect URIs

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=

# Resend (transactional emails)
RESEND_API_KEY=

# Email sender identity (used for both Resend + SMTP)
EMAIL_FROM_SUPPORT="AutoMindz Support" <support@automindz.com>
EMAIL_FROM_ONBOARDING="AutoMindz Team" <onboarding@automindz.com>

# SMTP (optional alternative to Resend)
# If RESEND_API_KEY is empty and SMTP_HOST is set, the app will send emails via SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_TLS_REJECT_UNAUTHORIZED=true

# Sentry (error tracking)
SENTRY_DSN=

# Bounce Webhook
BOUNCE_WEBHOOK_SECRET=

# Admin (comma-separated emails that get admin role on registration)
ADMIN_EMAILS=

