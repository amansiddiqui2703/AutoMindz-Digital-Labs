# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# In production, use your MongoDB Atlas URI
MONGODB_URI=mongodb://localhost:27017/automindz

# Redis Configuration
# Required for email queueing
REDIS_URL=redis://localhost:6379

# Security Configuration
# AES-256 encryption key (32 bytes / 64 hex chars)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# JWT Secret for authentication
JWT_SECRET=your-very-secret-key-change-this
JWT_EXPIRES_IN=7d

# Frontend & Backend Base URLs
APP_URL=http://localhost:5173
SERVER_URL=http://localhost:5000

# Email Configuration (Resend)
# EXCLUSIVELY used for system emails
RESEND_API_KEY=re_your_api_key

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Product Prices
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...

# Google OAuth2 Configuration
# Used for connecting user Gmail accounts
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:5000/api/accounts/google/callback

# Sentry Configuration (Error Tracking)
SENTRY_DSN=https://...@sentry.io/...

# Admin Settings
# Comma-separated list of emails that get admin role on signup
ADMIN_EMAILS=admin@example.com

# Other Secrets
BOUNCE_WEBHOOK_SECRET=your-bounce-secret
